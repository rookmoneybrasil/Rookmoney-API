generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ───────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String?   // null for OAuth-only users
  googleId            String?   @unique
  hasOnboarded        Boolean   @default(false)
  plan                String    @default("FREE")   // FREE | PRO
  isAdmin             Boolean   @default(false)
  stripeCustomerId    String?
  stripeSubscriptionId String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  whatsappPhone       String?   @unique  // E.164 format: +5511999999999
  profileImage        String?   // URL da foto de perfil
  bio                 String?   // Descrição pessoal
  city                String?   // Cidade
  occupation          String?   // Profissão
  birthdate           DateTime? // Data de nascimento
  // Notification preferences
  notifBillReminder   Boolean   @default(true)
  notifCategoryLimit  Boolean   @default(true)
  notifMonthlyEmail   Boolean   @default(false)
  // Appearance preferences
  currency            String    @default("BRL")
  dateFormat          String    @default("dd/MM/yyyy")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  transactions          Transaction[]
  categories            Category[]
  goals                 Goal[]
  bills                 Bill[]
  budgets               Budget[]
  incomeSources         IncomeSource[]
  recurringTransactions RecurringTransaction[]
  people                Person[]
  personEntries         PersonEntry[]
  personEntryRecurring  PersonEntryRecurring[]
  feedbacks             Feedback[]
}

// ─── Category ───────────────────────────────────────────────────────

model Category {
  id        String  @id @default(cuid())
  name      String
  icon      String
  color     String
  isDefault Boolean @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions             Transaction[]
  bills                    Bill[]
  budgets                  Budget[]
  incomeSources            IncomeSource[]
  recurringTransactions    RecurringTransaction[]
  personEntries            PersonEntry[]
  personEntryRecurring     PersonEntryRecurring[]

  @@index([userId])
}

// ─── Transaction ────────────────────────────────────────────────────

model Transaction {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([categoryId])
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ─── RecurringTransaction ────────────────────────────────────────────

model RecurringTransaction {
  id             String          @id @default(cuid())
  name           String
  amount         Decimal         @db.Decimal(12, 2)
  type           TransactionType
  frequency      RecurringFreq   @default(MONTHLY)
  dayOfMonth     Int?            // 1-31
  description    String?
  isActive       Boolean         @default(true)
  lastAutoMonth  String?         // "YYYY-MM"
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
}

enum RecurringFreq {
  WEEKLY
  MONTHLY
  YEARLY
}

// ─── Goal ───────────────────────────────────────────────────────────

model Goal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @db.Decimal(12, 2)
  deadline      DateTime?
  description   String?
  icon          String?
  color         String?
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId])
}

model GoalContribution {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now())

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// ─── Budget ─────────────────────────────────────────────────────────

model Budget {
  id        String   @id @default(cuid())
  month     String   // "YYYY-MM"
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}

// ─── IncomeSource ────────────────────────────────────────────────────

model IncomeSource {
  id               String           @id @default(cuid())
  name             String
  type             IncomeSourceType @default(EMPLOYMENT)
  amount           Decimal          @db.Decimal(12, 2)
  isRecurring      Boolean          @default(true)
  dayOfMonth       Int?
  lastAutoPayMonth String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
}

enum IncomeSourceType {
  EMPLOYMENT
  FREELANCE
  RENTAL
  OTHER
}

// ─── Bill ───────────────────────────────────────────────────────────

model Bill {
  id                 String    @id @default(cuid())
  name               String
  amount             Decimal   @db.Decimal(12, 2)
  dueDate            DateTime
  isPaid             Boolean   @default(false)
  paidAt             DateTime?
  isRecurring        Boolean   @default(false)
  notes              String?
  installmentTotal      Int?
  installmentCurrent    Int?
  installmentGroupId    String?
  paidTransactionId     String?   // Transaction criada ao marcar como paga
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, dueDate])
  @@index([installmentGroupId])
}

// ─── Person ─────────────────────────────────────────────────────────

model Person {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  color     String?  // hex color for avatar
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   PersonEntry[]
  recurring PersonEntryRecurring[]

  @@index([userId])
}

enum PersonEntryType {
  THEY_OWE_ME  // they owe you — positive for you
  I_OWE_THEM   // you owe them — negative for you
}

// ─── PersonEntryRecurring — template para entradas mensais automáticas ───────

model PersonEntryRecurring {
  id          String          @id @default(cuid())
  type        PersonEntryType
  description String
  amount      Decimal         @db.Decimal(12, 2)
  dayOfMonth  Int             @default(1)   // dia do mês para criar a entrada
  isActive    Boolean         @default(true)
  notes       String?
  lastMonth   String?         // "YYYY-MM" — último mês processado
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  personId   String
  person     Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([personId])
}

model PersonEntry {
  id                 String          @id @default(cuid())
  type               PersonEntryType
  description        String
  amount             Decimal         @db.Decimal(12, 2)
  date               DateTime
  isSettled          Boolean         @default(false)
  settledAt          DateTime?
  notes              String?
  installmentTotal     Int?
  installmentCurrent   Int?
  installmentGroupId   String?
  settledTransactionId String?   // ID da Transaction criada ao acertar
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  personId   String
  person     Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([personId])
  @@index([userId])
  @@index([installmentGroupId])
}

// ─── Feedback ────────────────────────────────────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  type      String   // "bug" | "suggestion"
  title     String
  body      String
  status    String   @default("open") // open | reviewing | done
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
